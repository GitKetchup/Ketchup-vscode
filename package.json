{
  "name": "ketchup-vscode",
  "displayName": "Ketchup",
  "description": "Transform your git commits into cinematic story recaps and intelligence dashboards directly from VS Code",
  "version": "0.2.0",
  "publisher": "ketchup",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers",
    "Visualization"
  ],
  "keywords": [
    "git",
    "changelog",
    "recap",
    "momentum",
    "forensics",
    "analytics"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.git",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ketchup.connect",
        "title": "Ketchup: Connect Workspace",
        "icon": "$(plug)"
      },
      {
        "command": "ketchup.draftRecap",
        "title": "Ketchup: Draft Recap",
        "icon": "$(add)"
      },
      {
        "command": "ketchup.viewRecap",
        "title": "Ketchup: View Recap",
        "icon": "$(eye)"
      },
      {
        "command": "ketchup.refreshRecaps",
        "title": "Ketchup: Refresh Recaps",
        "icon": "$(refresh)"
      },
      {
        "command": "ketchup.openInBrowser",
        "title": "Ketchup: Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "ketchup.logout",
        "title": "Ketchup: Logout",
        "icon": "$(sign-out)"
      },
      {
        "command": "ketchup.createSchedule",
        "title": "Create Schedule",
        "icon": "$(add)"
      },
      {
        "command": "ketchup.editSchedule",
        "title": "Edit Schedule",
        "icon": "$(edit)"
      },
      {
        "command": "ketchup.deleteSchedule",
        "title": "Delete Schedule",
        "icon": "$(trash)"
      },
      {
        "command": "ketchup.toggleSchedule",
        "title": "Toggle Schedule",
        "icon": "$(watch)"
      },
      {
        "command": "ketchup.refreshSchedules",
        "title": "Refresh Schedules",
        "icon": "$(refresh)"
      },
      {
        "command": "ketchup.viewMomentum",
        "title": "Ketchup: View Momentum Dashboard",
        "icon": "$(pulse)"
      },
      {
        "command": "ketchup.viewForensics",
        "title": "Ketchup: View Forensics",
        "icon": "$(search)"
      },
      {
        "command": "ketchup.viewSkills",
        "title": "Ketchup: View Skills Graph",
        "icon": "$(organization)"
      },
      {
        "command": "ketchup.refreshIntelligence",
        "title": "Refresh Intelligence",
        "icon": "$(refresh)"
      },
      {
        "command": "ketchup.setupLocal",
        "title": "Ketchup: Setup Local Mode",
        "icon": "$(desktop-download)"
      },
      {
        "command": "ketchup.checkLocalHealth",
        "title": "Ketchup: Check Local Engine Status",
        "icon": "$(server)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ketchup",
          "title": "Ketchup",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "ketchup": [
        {
          "id": "ketchup.recaps",
          "name": "Recaps"
        },
        {
          "id": "ketchup.schedules",
          "name": "Schedules"
        },
        {
          "id": "ketchup.intelligence",
          "name": "Intelligence",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ketchup.draftRecap",
          "when": "view == ketchup.recaps",
          "group": "navigation"
        },
        {
          "command": "ketchup.refreshRecaps",
          "when": "view == ketchup.recaps",
          "group": "navigation"
        },
        {
          "command": "ketchup.logout",
          "when": "view == ketchup.recaps",
          "group": "navigation"
        },
        {
          "command": "ketchup.createSchedule",
          "when": "view == ketchup.schedules",
          "group": "navigation"
        },
        {
          "command": "ketchup.refreshSchedules",
          "when": "view == ketchup.schedules",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ketchup.viewRecap",
          "when": "view == ketchup.recaps && viewItem == recap",
          "group": "inline"
        },
        {
          "command": "ketchup.openInBrowser",
          "when": "view == ketchup.recaps && viewItem == recap"
        },
        {
          "command": "ketchup.editSchedule",
          "when": "view == ketchup.schedules && viewItem == schedule",
          "group": "inline"
        },
        {
          "command": "ketchup.toggleSchedule",
          "when": "view == ketchup.schedules && viewItem == schedule",
          "group": "inline"
        },
        {
          "command": "ketchup.deleteSchedule",
          "when": "view == ketchup.schedules && viewItem == schedule"
        }
      ]
    },
    "configuration": {
      "title": "Ketchup",
      "properties": {
        "ketchup.apiUrl": {
          "type": "string",
          "defaults": "https://app.gitketchup.com",
          "default": "http://localhost:3003",
          "description": "Ketchup API base URL (for self-hosted instances)"
        },
        "ketchup.mode": {
          "type": "string",
          "enum": [
            "cloud",
            "local",
            "mixed"
          ],
          "default": "cloud",
          "description": "Operation mode: cloud (default), local-only, or mixed"
        },
        "ketchup.defaultTimeRange": {
          "type": "number",
          "enum": [
            7,
            14,
            30
          ],
          "default": 7,
          "description": "Default time range for drafting recaps (in days)"
        },
        "ketchup.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh recaps when workspace opens"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./dist/test/runTest.js",
    "package": "vsce package",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^11.7.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "simple-git": "^3.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ketchup-vscode"
  },
  "bugs": {
    "url": "https://github.com/yourusername/ketchup-vscode/issues"
  },
  "homepage": "https://gitketchup.com"
}